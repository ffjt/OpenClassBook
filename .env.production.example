# Required production deployment values
VITE_API_BASE_URL=https://api.example.com
CORS_ORIGINS=["https://app.example.com"]
AUTH_JWT_SECRET=replace-with-a-unique-random-secret-of-at-least-32-characters

# Choose exactly one email provider: SMTP example
AUTH_EMAIL_PROVIDER=smtp
AUTH_SMTP_HOST=smtp.example.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=mailer@example.com
AUTH_SMTP_PASSWORD=replace-with-smtp-password
AUTH_SMTP_FROM_EMAIL=mailer@example.com

# Tencent SES alternative (uncomment this block and remove the SMTP values)
# AUTH_EMAIL_PROVIDER=tencent_ses
# AUTH_TENCENT_SES_REGION=ap-guangzhou
# AUTH_TENCENT_SES_FROM_EMAIL=mailer@example.com
# AUTH_TENCENT_SES_TEMPLATE_ID=123456
# TENCENTCLOUD_SECRET_ID=replace-with-secret-id
# TENCENTCLOUD_SECRET_KEY=replace-with-secret-key
