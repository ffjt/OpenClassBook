DATABASE_URL=sqlite:///./openclassbook.db
APP_ENVIRONMENT=development
# Production requires a unique, randomly generated secret of at least 32 characters.
AUTH_JWT_SECRET=
# Keep false in production. Set CORS_ORIGINS to the exact public frontend origins.
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# Allows localhost and private-LAN frontend addresses on any development port.
# 允许 localhost 与局域网前端地址使用任意开发端口。
CORS_ORIGIN_REGEX=^https?://(?:localhost|127\.0\.0\.1|10(?:\.\d{1,3}){3}|192\.168(?:\.\d{1,3}){2}|172\.(?:1[6-9]|2\d|3[01])(?:\.\d{1,3}){2})(?::\d+)?$
# Production email: choose smtp or tencent_ses. The Docker deployment sample is
# ../.env.production.example and requires all fields for the chosen provider.
AUTH_EMAIL_PROVIDER=unconfigured
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_FROM_EMAIL=
AUTH_TENCENT_SES_REGION=ap-guangzhou
AUTH_TENCENT_SES_FROM_EMAIL=
AUTH_TENCENT_SES_TEMPLATE_ID=
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
