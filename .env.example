# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
DATABASE_URL=sqlite:///./openclassbook.db

# Authentication (use a long, random value in every deployed environment)
AUTH_JWT_SECRET=replace-with-a-long-random-secret
# Email verification is provider-based. Set SMTP values to enable registration.
AUTH_EMAIL_PROVIDER=smtp
AUTH_SMTP_HOST=smtp.example.com
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_FROM_EMAIL=no-reply@example.com

# Tencent Cloud SES (set AUTH_EMAIL_PROVIDER=tencent_ses to use this provider)
# Credentials are read by Tencent's SDK from TENCENTCLOUD_SECRET_ID and
# TENCENTCLOUD_SECRET_KEY. Verify the sending domain in Tencent Cloud first.
AUTH_TENCENT_SES_REGION=ap-guangzhou
AUTH_TENCENT_SES_FROM_EMAIL=OpenClassBook <no-reply@example.com>
AUTH_TENCENT_SES_TEMPLATE_ID=
